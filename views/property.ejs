<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= property.title %> - Real Estate Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://maps.googleapis.com/maps/api/js?key=YOUR_API_KEY"></script>
</head>
<body>
    <%- include('partials/header') %>

    <div class="container mt-4">
        <div class="row">
            <div class="col-md-8">
                <h1><%= property.title %></h1>
                <img src="<%= property.image || 'https://via.placeholder.com/600x400' %>" class="img-fluid mb-3" alt="Property">
                <p><strong>Price:</strong> $<%= property.price.toLocaleString() %></p>
                <p><strong>Location:</strong> <%= property.location %></p>
                <p><strong>Bedrooms:</strong> <%= property.bedrooms %></p>
                <p><strong>Bathrooms:</strong> <%= property.bathrooms %></p>
                <p><strong>Type:</strong> <%= property.home_type %></p>
                <p><%= property.description %></p>
                <h3>3D Virtual Tour</h3>
                <div id="virtual-tour" style="height: 400px; background: #f0f0f0;">[Virtual Tour Placeholder - Integrate Matterport or similar]</div>
            </div>
            <div class="col-md-4">
                <h3>Interactive Map</h3>
                <div id="map" style="height: 300px;"></div>
                <h3>Mortgage Calculator</h3>
                <form id="mortgage-form">
                    <div class="mb-3">
                        <label>Down Payment (%)</label>
                        <input type="number" id="downPayment" class="form-control" value="20">
                    </div>
                    <div class="mb-3">
                        <label>Interest Rate (%)</label>
                        <input type="number" id="interestRate" class="form-control" value="3.5" step="0.1">
                    </div>
                    <div class="mb-3">
                        <label>Loan Term (years)</label>
                        <input type="number" id="loanTerm" class="form-control" value="30">
                    </div>
                    <button type="button" id="calculate" class="btn btn-primary">Calculate</button>
                </form>
                <div id="results" class="mt-3"></div>
                <h3>Contact Agent</h3>
                <form action="/contact" method="POST">
                    <input type="hidden" name="property" value="<%= property.id %>">
                    <div class="mb-3">
                        <input type="text" name="name" class="form-control" placeholder="Your Name" required>
                    </div>
                    <div class="mb-3">
                        <input type="email" name="email" class="form-control" placeholder="Email" required>
                    </div>
                    <div class="mb-3">
                        <textarea name="message" class="form-control" placeholder="Message" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Send Message</button>
                </form>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Map
        function initMap() {
            const map = new google.maps.Map(document.getElementById('map'), {
                center: { lat: <%= property.lat || 40.7128 %>, lng: <%= property.lng || -74.0060 %> },
                zoom: 15
            });
            new google.maps.Marker({
                position: { lat: <%= property.lat || 40.7128 %>, lng: <%= property.lng || -74.0060 %> },
                map: map
            });
        }
        initMap();

        // Mortgage Calculator
        document.getElementById('calculate').addEventListener('click', () => {
            const price = <%= property.price %>;
            const downPaymentPercent = parseFloat(document.getElementById('downPayment').value) / 100;
            const interestRate = parseFloat(document.getElementById('interestRate').value) / 100 / 12;
            const loanTerm = parseInt(document.getElementById('loanTerm').value) * 12;
            const downPayment = price * downPaymentPercent;
            const loanAmount = price - downPayment;
            const monthlyPayment = loanAmount * (interestRate * Math.pow(1 + interestRate, loanTerm)) / (Math.pow(1 + interestRate, loanTerm) - 1);
            document.getElementById('results').innerHTML = `
                <p>Down Payment: $${downPayment.toLocaleString()}</p>
                <p>Monthly Payment: $${monthlyPayment.toFixed(2)}</p>
                <p>Total Interest: $${((monthlyPayment * loanTerm) - loanAmount).toFixed(2)}</p>
            `;
        });
    </script>
</body>
</html>