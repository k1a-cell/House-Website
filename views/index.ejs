<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Real Estate Pro - Rentals. Homes.</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('partials/header') %>

    <main>
        <section class="hero bg-light py-5">
            <div class="container text-center">
                <h1 class="display-4">Rentals. Homes.</h1>
                <div class="search-bar mt-4">
                    <form id="searchForm" class="d-flex justify-content-center">
                        <input type="text" name="location" class="form-control me-2" placeholder="Enter an address, neighborhood, city, or ZIP code" style="max-width: 400px;">
                        <button type="submit" class="btn btn-primary">Search</button>
                    </form>
                </div>
                <p class="mt-3">Get home recommendations</p>
                <% if (!user) { %>
                    <a href="/login" class="btn btn-outline-primary">Sign in</a> for a more personalized experience.
                <% } %>
            </div>
        </section>

        <section class="buyability py-5">
            <div class="container text-center">
                <h2>Find homes you can afford with BuyAbility℠</h2>
                <p>Answer a few questions. We'll highlight homes you're likely to qualify for.</p>
                <a href="/mortgage" class="btn btn-primary">Let's get started</a>
            </div>
        </section>

        <section class="properties py-5 bg-light">
            <div class="container">
                <h2 class="text-center mb-4">Recommended Homes</h2>
                <div class="row">
                    <% // Sample properties, in real app fetch from DB %>
                    <div class="col-md-4 mb-4">
                        <div class="card">
                            <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="Home">
                            <div class="card-body">
                                <h5 class="card-title">$500,000</h5>
                                <p class="card-text">3 beds, 2 baths</p>
                                <a href="/property/1" class="btn btn-primary">View Details</a>
                            </div>
                        </div>
                    </div>
                    <!-- Add more -->
                </div>
            </div>
        </section>

        <section class="services py-5">
            <div class="container">
                <div class="row text-center">
                    <div class="col-md-4">
                        <h4>Buy a home</h4>
                        <p>Find your dream home with our expert guidance.</p>
                        <a href="/properties?type=buy" class="btn btn-primary">Find Homes</a>
                    </div>
                    <div class="col-md-4">
                        <h4>Rent a home</h4>
                        <p>Discover rental properties in your area.</p>
                        <a href="/properties?type=rent" class="btn btn-primary">Find Rentals</a>
                    </div>
                    <div class="col-md-4">
                        <h4>Sell a home</h4>
                        <p>Get the best price for your property.</p>
                        <a href="/contact" class="btn btn-primary">Contact Agent</a>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/script.js"></script>
    <script>
        document.getElementById('searchForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const location = e.target.location.value;
            window.location.href = `/properties?location=${encodeURIComponent(location)}`;
        });
    </script>
</body>
</html>