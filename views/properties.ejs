<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Properties - Real Estate Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('partials/header') %>

    <div class="container mt-4">
        <h1>Property Listings</h1>
        <form action="/properties" method="GET" class="mb-4">
            <div class="row g-3">
                <div class="col-md-2">
                    <select name="type" class="form-select">
                        <option value="">All Types</option>
                        <option value="buy" <%= filters.type === 'buy' ? 'selected' : '' %>>Buy</option>
                        <option value="rent" <%= filters.type === 'rent' ? 'selected' : '' %>>Rent</option>
                        <option value="sell" <%= filters.type === 'sell' ? 'selected' : '' %>>Sell</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="number" name="minPrice" class="form-control" placeholder="Min Price" value="<%= filters.minPrice || '' %>">
                </div>
                <div class="col-md-2">
                    <input type="number" name="maxPrice" class="form-control" placeholder="Max Price" value="<%= filters.maxPrice || '' %>">
                </div>
                <div class="col-md-2">
                    <input type="text" name="location" class="form-control" placeholder="Location" value="<%= filters.location || '' %>">
                </div>
                <div class="col-md-1">
                    <input type="number" name="bedrooms" class="form-control" placeholder="Beds" value="<%= filters.bedrooms || '' %>">
                </div>
                <div class="col-md-1">
                    <input type="number" name="bathrooms" class="form-control" placeholder="Baths" value="<%= filters.bathrooms || '' %>">
                </div>
                <div class="col-md-2">
                    <select name="homeType" class="form-select">
                        <option value="">Home Type</option>
                        <option value="house" <%= filters.homeType === 'house' ? 'selected' : '' %>>House</option>
                        <option value="apartment" <%= filters.homeType === 'apartment' ? 'selected' : '' %>>Apartment</option>
                        <option value="land" <%= filters.homeType === 'land' ? 'selected' : '' %>>Land</option>
                    </select>
                </div>
            </div>
            <button type="submit" class="btn btn-primary mt-3">Search</button>
        </form>

        <div class="row">
            <% properties.forEach(property => { %>
                <div class="col-md-4 mb-4">
                    <div class="card">
                        <img src="<%= property.image || 'https://via.placeholder.com/300x200' %>" class="card-img-top" alt="Property">
                        <div class="card-body">
                            <h5 class="card-title"><%= property.title %> - $<%= property.price.toLocaleString() %></h5>
                            <p class="card-text"><%= property.bedrooms %> beds, <%= property.bathrooms %> baths</p>
                            <p><%= property.location %></p>
                            <a href="/property/<%= property.id %>" class="btn btn-primary">View Details</a>
                            <% if (user) { %>
                                <form action="/favorite/<%= property.id %>" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-outline-secondary">Save</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script>
        window.user = <%- JSON.stringify(user) %>;
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Properties filtering AJAX
        function updateProperties() {
            const form = document.querySelector('form[action="/properties"]');
            const formData = new FormData(form);
            const params = new URLSearchParams(formData);
            fetch(`/api/properties?${params}`)
                .then(response => response.json())
                .then(properties => {
                    const container = document.querySelector('.row');
                    container.innerHTML = '';
                    properties.forEach(property => {
                        const col = document.createElement('div');
                        col.className = 'col-md-4 mb-4';
                        col.innerHTML = `
                            <div class="card">
                                <img src="${property.image || 'https://via.placeholder.com/300x200'}" class="card-img-top" alt="Property">
                                <div class="card-body">
                                    <h5 class="card-title">${property.title} - $${property.price.toLocaleString()}</h5>
                                    <p class="card-text">${property.bedrooms} beds, ${property.bathrooms} baths</p>
                                    <p>${property.location}</p>
                                    <a href="/property/${property.id}" class="btn btn-primary">View Details</a>
                                    ${window.user ? `<button class="btn btn-outline-secondary save-btn" data-id="${property.id}">Save</button>` : ''}
                                </div>
                            </div>
                        `;
                        container.appendChild(col);
                    });
                })
                .catch(error => console.error('Error fetching properties:', error));
        }

        document.addEventListener('DOMContentLoaded', () => {
            const form = document.querySelector('form[action="/properties"]');
            const inputs = form.querySelectorAll('input, select');
            inputs.forEach(input => {
                input.addEventListener('input', updateProperties);
                input.addEventListener('change', updateProperties);
            });
            // Remove the submit button or make it not submit
            const submitBtn = form.querySelector('button[type="submit"]');
            if (submitBtn) {
                submitBtn.style.display = 'none';
            }

            // Save button AJAX
            document.addEventListener('click', (e) => {
                if (e.target.classList.contains('save-btn')) {
                    const id = e.target.dataset.id;
                    fetch(`/api/favorite/${id}`, { method: 'POST' })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                e.target.textContent = 'Saved';
                                e.target.classList.remove('btn-outline-secondary');
                                e.target.classList.add('btn-success');
                            }
                        })
                        .catch(error => console.error('Error saving:', error));
                }
            });
        });
    </script>
</body>
</html>